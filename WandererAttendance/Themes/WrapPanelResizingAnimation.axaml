<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:assists="clr-namespace:WandererAttendance.Assists">
    <Design.PreviewWith>
        <Border Padding="20">
            <!-- Add Controls for Previewer Here -->
        </Border>
    </Design.PreviewWith>

    <Style Selector=":is(Panel).animated-resize">
        <Setter Property="assists:WrapPanelResizingAnimationAssist.IsResizingAnimationEnabled" Value="True"/>
    </Style>
</Styles>
