<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:faStyling="using:FluentAvalonia.Styling"
        xmlns:faWindowing="using:FluentAvalonia.UI.Windowing"
        xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
        xmlns:controls="clr-namespace:WandererAttendance.Controls"
        xmlns:faControls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia">
    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <MergeResourceInclude Source="/Themes/MultiComboBox.axaml" />
                <MergeResourceInclude Source="/Themes/ChipListBox.axaml" />
                <MergeResourceInclude Source="/Controls/AttendanceCalendarControl.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Styles.Resources>
    
    <faStyling:FluentAvaloniaTheme PreferSystemTheme="True"
                                   PreferUserAccentColor="True"
                                   UseSystemFontOnWindows="False"
                                   TextVerticalAlignmentOverrideBehavior="Disabled" />
    
    <StyleInclude Source="/Themes/TabStrip.axaml"/>
    <StyleInclude Source="/Themes/PopupAnimations.axaml"/>
    <StyleInclude Source="/Themes/StackPanelIntroAnimation.axaml"/>
    <StyleInclude Source="/Themes/WrapPanelResizingAnimation.axaml"/>
    <StyleInclude Source="/Controls/Field.axaml"/>
    
    <Style Selector="TextBlock :is(HyperlinkButton)">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0 0 0 -4"/>
        <Setter Property="TextBlock.LineHeight" Value="NaN"/>
        <Style Selector="^ TextBlock">
            <!-- 修复字体飞上去的问题 -->
            <Setter Property="Margin" Value="0 0 0 -2"/>
        </Style>
    </Style>

    <Style Selector=":is(faWindowing|AppWindow)">
        <Setter Property="Icon" Value="/Assets/AppLogo.png"/>
        <Setter Property="FontFamily" Value="{StaticResource HarmonyOsSansSc}" />
    </Style>
    
    <Style Selector="asyncImageLoader|AdvancedImage">
        <Setter Property="Template">
            <ControlTemplate>
                <Grid x:Name="Root" Classes.empty="{TemplateBinding CurrentImage, Converter={x:Static ObjectConverters.IsNull}, Mode=OneWay}">
                    <controls:FluentIcon VerticalAlignment="Center" HorizontalAlignment="Center"
                                         Glyph="&#xE9CC;"
                                         IsVisible="False" IsHitTestVisible="False"
                                         x:Name="FluentIconError"
                                         FontSize="18"
                                         Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>
                </Grid>
            </ControlTemplate>
        </Setter>

        <Style Selector="^[IsLoading=False] /template/ Grid#Root.empty">
            <Style Selector="^ Border#LoadingBorder">
                <Setter Property="IsVisible" Value="True"/>
                <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}"/>
                <Setter Property="ToolTip.Tip" Value="喔唷，图裂啦"/>
            </Style>
            <Style Selector="^ controls|FluentIcon#FluentIconError">
                <Setter Property="IsVisible" Value="True"/>
            </Style>
        </Style>
    </Style>
    
    <Style Selector=":is(UserControl).browser faControls|SettingsExpander /template/ Expander#Expander">
        <Setter Property="faControls:ExpanderExt.ExpanderAnimationType" Value="{x:Null}" />
    </Style>
    
    <Style Selector="Carousel.animated">
        <Setter Property="PageTransition">
            <Setter.Value>
                <CompositePageTransition>
                    <PageSlide Duration="0:0:0.3" Orientation="Horizontal"
                               SlideOutEasing="0.76, 0, 0.24, 1"
                               SlideInEasing="0.76, 0, 0.24, 1"/>
                    <CrossFade Duration="0:0:0.3"/>
                </CompositePageTransition>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style Selector="TabControl TabItem, TabStrip TabStripItem">
        <Style Selector="^ TextBlock">
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
    </Style>

    <Style Selector="TabControl.compact TabItem">
        <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="TextElement.FontSize" Value="14"/>
            <Setter Property="TextElement.FontWeight" Value="Medium"/>
        </Style>
        <Setter Property="MinHeight" Value="28"/>
    </Style>
    
    <Style Selector="TabStrip.compact TabStripItem">
        <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="TextElement.FontSize" Value="14"/>
            <Setter Property="TextElement.FontWeight" Value="Medium"/>
        </Style>
        <Setter Property="MinHeight" Value="28"/>
    </Style>
    
    <Style Selector="Expander.compact">
        <Setter Property="Padding" Value="8"/>
        <Style Selector="^ /template/ ToggleButton#ExpanderHeader">
            <Setter Property="MinHeight" Value="36"/>
        </Style>
        <Style Selector="^ /template/ ToggleButton#ExpanderHeader /template/ Border#Root">
            <Setter Property="Padding" Value="8 0 0 0"/>
        </Style>
        <Style Selector="^ /template/ ToggleButton#ExpanderHeader /template/ Border#ExpandCollapseChevronBorder">
            <Setter Property="Margin" Value="4,-8,8,-8"/>
        </Style>
    </Style>
    
    <Style Selector="Expander.stretch-header /template/ ToggleButton#ExpanderHeader /template/ ContentPresenter#ContentPresenter">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>
</Styles>
