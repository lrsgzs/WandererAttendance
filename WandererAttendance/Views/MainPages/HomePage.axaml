<UserControl x:Class="WandererAttendance.Views.MainPages.HomePage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="using:WandererAttendance.Views.MainPages"
             xmlns:controls="clr-namespace:WandererAttendance.Controls"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d"
             x:DataType="local:HomePage"
             d:DataContext="{d:DesignInstance local:HomePage}">
    <ScrollViewer Margin="12 12 18 12">
        <StackPanel Orientation="Vertical" Spacing="8" Classes="animated-intro">
            <TextBlock FontSize="16">
                日期:
                <Run Text="{Binding ViewModel.TodayDate}" />
            </TextBlock>
            
            <Button Classes="accent" HorizontalAlignment="Stretch"
                    Click="GoAttendancePageButton_OnClick">
                <controls:IconText Glyph="&#xE0AA;" Text="去考勤" />
            </Button>
            
            <Expander Header="今日考勤状态" IsExpanded="True">
                <ItemsControl ItemsSource="{Binding ViewModel.AttendanceData}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" Spacing="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
    
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Vertical" Spacing="2">
                                <TextBlock>
                                    <Run Text="{Binding Status.Name}" />
                                    <Run Text="{Binding Count}" />
                                    人
                                </TextBlock>
                                
                                <ItemsControl ItemsSource="{Binding Persons}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" ItemSpacing="4" LineSpacing="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
